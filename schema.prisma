generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role { MANAGER DRIVER }
enum ReviewStatus { PENDING APPROVED REJECTED }
enum StopStatus { UNASSIGNED ASSIGNED EN_ROUTE ARRIVED DELIVERED ISSUE }

model User {
  id Int @id @default(autoincrement())
  name String
  email String @unique
  passwordHash String
  role Role
  createdAt DateTime @default(now())
  driver Driver?
}

model Driver {
  id Int @id @default(autoincrement())
  userId Int @unique
  user User @relation(fields: [userId], references: [id])
  phone String?
  active Boolean @default(true)
  targetMinutes Int @default(330)
  maxBoxes Int @default(150)
  color String @default("#2563eb")
  currentLat Float?
  currentLng Float?
  locationUpdatedAt DateTime?
  shiftStartedAt DateTime?
  online Boolean @default(false)
  stops DeliveryStop[]
  locations DriverLocation[]
}

model InvoiceUpload {
  id Int @id @default(autoincrement())
  filename String
  storedName String
  mimeType String
  uploadedById Int
  uploadedAt DateTime @default(now())
  reviewStatus ReviewStatus @default(PENDING)
  extracted ExtractedStop[]
}

model ExtractedStop {
  id Int @id @default(autoincrement())
  uploadId Int
  upload InvoiceUpload @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  customerName String
  address String
  invoiceNumber String?
  invoiceValue Float @default(0)
  boxCount Int @default(0)
  routeHint String?
  confidence Float @default(0.5)
  reviewStatus ReviewStatus @default(PENDING)
  deliveryStopId Int? @unique
  deliveryStop DeliveryStop? @relation(fields: [deliveryStopId], references: [id])
}

model Customer {
  id Int @id @default(autoincrement())
  name String
  address String
  latitude Float?
  longitude Float?
  createdAt DateTime @default(now())
  stops DeliveryStop[]
  @@unique([name, address])
}

model DeliveryStop {
  id Int @id @default(autoincrement())
  serviceDate DateTime
  customerId Int
  customer Customer @relation(fields: [customerId], references: [id])
  invoiceNumber String?
  invoiceValue Float @default(0)
  boxCount Int @default(0)
  routeHint String?
  status StopStatus @default(UNASSIGNED)
  driverId Int?
  driver Driver? @relation(fields: [driverId], references: [id])
  sequence Int @default(0)
  estimatedServiceMinutes Int @default(8)
  extractedStop ExtractedStop?
  notes String?
  proofPhotoUrl String?
  deliveredBoxes Int?
  arrivedAt DateTime?
  deliveredAt DateTime?
  createdAt DateTime @default(now())
}


model DriverLocation {
  id Int @id @default(autoincrement())
  driverId Int
  driver Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)
  latitude Float
  longitude Float
  accuracy Float?
  speed Float?
  heading Float?
  createdAt DateTime @default(now())
}
